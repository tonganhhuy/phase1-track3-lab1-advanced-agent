# Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Enable live API calls (set to true/1/yes, default is false)
LIVE_MODE=true

# Model choice (default: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Request Per Minute limit to prevent 429 rate limit errors (default: 15)
# Set higher if you are using a paid tier with higher limits
GEMINI_RPM=15
